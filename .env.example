# =====================================================
# RL TRADER V4 — Arquivo de Configuração de Ambiente
# =====================================================
# INSTRUÇÕES:
#   1. Copie este arquivo para C:\RL_Trader\.env  (no VPS)
#   2. Preencha os valores com SUA credencial
#   3. NUNCA commite o .env real no GitHub
# =====================================================

# --- Ambiente ---
ENV=PROD
PROJECT_NAME=RL TRADER V4

# --- Banco de Dados (MySQL Hostinger) ---
DB_HOST=srv1161.hstgr.io
DB_PORT=3306
DB_USER=u116771474_bot
DB_PASSWORD=SUA_SENHA_AQUI
DB_NAME=u116771474_rl_trader

# --- MetaTrader 5 ---
MT5_LOGIN=SEU_LOGIN_MT5
MT5_PASSWORD=SUA_SENHA_MT5
MT5_SERVER=SEU_SERVIDOR_MT5
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
MT5_TIMEOUT_SEC=30
MT5_TIME_SYNC_SYMBOL=EURUSD

# --- API do Bot ---
API_PORT=8001
API_KEY=SUA_API_KEY_SECRETA

# --- Finnhub (Notícias / Sentimento) ---
# Crie sua key gratuita em: https://finnhub.io/register
FINNHUB_API_KEY=SUA_FINNHUB_API_KEY_AQUI

# --- Notificações (ntfy.sh) ---
NOTIFICATIONS_ENABLED=True
NTFY_TOPIC=rl_trader_v3_alerts
NTFY_BASE_URL=https://ntfy.sh
NOTIFY_MIN_SEVERITY=ERROR

# --- Logs e Resiliência ---
LOG_LEVEL=INFO
DISK_MIN_FREE_GB=1.0
TIME_SKEW_MAX_SEC=30.0
HEARTBEAT_INTERVAL_SEC=5

# --- Asset Selection ---
SELECTION_MODE=manual
SELECTION_MAX_ACTIVE=5
SELECTION_MIN_SCORE=20.0
SELECTION_REBALANCE_MINUTES=60

# --- Estratégias ---
STRATEGY_ENABLE_TREND=True
STRATEGY_ENABLE_REVERSION=True
STRATEGY_ENABLE_BREAKOUT=False
STRATEGY_THRESHOLD_CONSERVATIVE=60.0
STRATEGY_THRESHOLD_BALANCED=40.0
STRATEGY_THRESHOLD_AGGRESSIVE=30.0

# --- Execução ---
EXECUTION_RISK_PER_TRADE=0.01
EXECUTION_MAX_LOT=1.0
EXECUTION_MIN_LOT=0.01

# --- Risco ---
RISK_MAX_DRAWDOWN_PCT=0.15
RISK_MAX_EXPOSURE_TOTAL=5.0

# --- Sessão ---
SESSION_CLOSE_WINNERS_IMMEDIATELY=True
SESSION_LOSER_REVERSAL_WINDOW_MINUTES=30
